{
  "kind": "openhands-invocation-schema-spec",
  "name": "invocation-report-section",
  "description": "Report section shape for disabled invocation summaries.",
  "requiredFields": ["kind", "heading", "status", "statusCard", "dryRunChecklist", "postRunChecklist", "lines", "markdown"],
  "allowedStatusValues": ["setup-gated", "blocked", "refused", "validation-failed", "timeout", "output-capped", "invalid-response", "not-implemented", "disabled"],
  "safetyBooleansMustBeFalse": ["patchApproved", "commitAllowed", "pushAllowed", "mergeAllowed", "branchDeletionAllowed", "resetAllowed", "stashPopAllowed", "mainMasterWriteAllowed", "privateMemoryAccessAllowed", "dependencyProvisioningAllowed"],
  "humanReviewFieldsMustBeTrue": ["requiresHumanReview", "requiresSeparatePostRunApproval"],
  "forbiddenSecretFields": ["apiKey", "apiKeyValue", "secret", "token", "password", "privateKey"],
  "allowedEndpointPatterns": ["^http://localhost(:[0-9]+)?(/.*)?$", "^http://127\\.0\\.0\\.1(:[0-9]+)?(/.*)?$", "^http://example\\.invalid(:[0-9]+)?(/.*)?$"],
  "nonAuthorizing": true
}
