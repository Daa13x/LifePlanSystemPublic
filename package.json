{
  "name": "life-planner",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first Life Planner personal assistant MVP.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node server/index.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.js",
    "check": "npm run build",
    "policy:cloud-main": "node scripts/check-cloud-main.mjs",
    "verify:executor-enforcement": "node scripts/verify-executor-enforcement.mjs",
    "verify:openhands-invocation-adapter": "node scripts/verify-openhands-invocation-adapter.mjs",
    "verify:openhands-invocation-schemas": "node scripts/verify-openhands-invocation-schemas.mjs",
    "verify:openhands-invocation-all": "npm run verify:openhands-invocation-adapter && npm run verify:openhands-invocation-schemas",
    "verify:runcli-cwd": "node scripts/verify-runcli-cwd.mjs",
    "verify:source-control-safety": "node scripts/verify-source-control-safety.mjs",
    "verify:source-control-api": "node scripts/verify-source-control-api.mjs",
    "verify:git-authority-policy": "node scripts/verify-git-authority-policy.mjs",
    "verify:governance-safety": "node scripts/verify-governance-safety.mjs",
    "verify:browser-connector-safety": "node scripts/verify-browser-connector-safety.mjs",
    "verify:browser-extension-install": "node scripts/verify-browser-extension-install.mjs",
    "verify:tray-launcher": "node scripts/verify-tray-launcher.mjs",
    "verify:portable-package": "node scripts/verify-portable-package.mjs",
    "verify:openhands-stop-boundary": "node scripts/verify-openhands-stop-boundary.mjs",
    "verify:local-ai-docs": "node scripts/verify-local-ai-docs.mjs",
    "verify:native-coding-worker": "node scripts/verify-native-coding-worker.mjs",
    "verify:browser-assisted-coding": "node scripts/verify-browser-assisted-coding.mjs",
    "verify:runtime-safety": "npm run verify:runcli-cwd && npm run verify:source-control-safety && npm run verify:source-control-api && npm run verify:git-authority-policy && npm run verify:governance-safety && npm run verify:browser-connector-safety && npm run verify:browser-extension-install && npm run verify:tray-launcher && npm run verify:executor-enforcement && npm run verify:openhands-invocation-all && npm run verify:openhands-stop-boundary && npm run verify:local-ai-docs && npm run verify:native-coding-worker && npm run verify:browser-assisted-coding",
    "verify:lifeskillsystem-skills": "node scripts/verify-lifeskillsystem-skills.mjs",
    "verify:local-learning-event-schema": "node scripts/verify-local-learning-event-schema.mjs",
    "verify:local-learning-event-validator": "node scripts/verify-local-learning-event-validator.mjs",
    "verify:local-learning-event-writer": "node scripts/verify-local-learning-event-writer.mjs",
    "verify:local-learning-review-inbox-reader": "node scripts/verify-local-learning-review-inbox-reader.mjs",
    "package:portable": "powershell -ExecutionPolicy Bypass -File scripts/package-portable.ps1",
    "package:inno": "powershell -ExecutionPolicy Bypass -File scripts/package-portable.ps1 && ISCC.exe installer/LifePlannerPortable.iss"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "express": "4.22.2",
    "lucide-react": "^0.468.0",
    "marked": "^14.1.4",
    "pdfjs-dist": "^6.1.200",
    "playwright": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "concurrently": "9.2.0"
  },
  "overrides": {
    "body-parser": "1.20.6",
    "shell-quote": "1.10.0"
  }
}
