{
  "name": "life-planner",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Life Planner personal assistant MVP.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node server/index.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.js",
    "check": "npm run build",
    "verify:executor-enforcement": "node scripts/verify-executor-enforcement.mjs",
    "verify:openhands-invocation-adapter": "node scripts/verify-openhands-invocation-adapter.mjs",
    "verify:openhands-invocation-schemas": "node scripts/verify-openhands-invocation-schemas.mjs",
    "verify:openhands-invocation-all": "npm run verify:openhands-invocation-adapter && npm run verify:openhands-invocation-schemas",
    "verify:runcli-cwd": "node scripts/verify-runcli-cwd.mjs",
    "verify:openhands-stop-boundary": "node scripts/verify-openhands-stop-boundary.mjs",
    "verify:runtime-safety": "npm run verify:runcli-cwd && npm run verify:executor-enforcement && npm run verify:openhands-invocation-all && npm run verify:openhands-stop-boundary",
    "verify:lifeskillsystem-skills": "node scripts/verify-lifeskillsystem-skills.mjs",
    "verify:local-learning-event-schema": "node scripts/verify-local-learning-event-schema.mjs",
    "verify:local-learning-event-validator": "node scripts/verify-local-learning-event-validator.mjs",
    "verify:local-learning-event-writer": "node scripts/verify-local-learning-event-writer.mjs",
    "verify:local-learning-review-inbox-reader": "node scripts/verify-local-learning-review-inbox-reader.mjs",
    "package:portable": "powershell -ExecutionPolicy Bypass -File scripts/package-portable.ps1",
    "package:inno": "powershell -ExecutionPolicy Bypass -File scripts/package-portable.ps1 && ISCC.exe installer/LifePlannerPortable.iss"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "marked": "^14.1.4",
    "playwright": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  }
}
